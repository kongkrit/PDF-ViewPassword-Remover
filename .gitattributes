# Default: normalise line endings to LF in the repo
* text=auto eol=lf

# Web source files — always LF
*.html          text eol=lf
*.css           text eol=lf
*.js            text eol=lf
*.json          text eol=lf
*.webmanifest   text eol=lf
*.md            text eol=lf
*.yml           text eol=lf
*.yaml          text eol=lf
*.txt           text eol=lf

# Binary — no line-ending or diff mangling
*.wasm          binary
*.pdf           binary
*.png           binary
*.jpg           binary
*.ico           binary
